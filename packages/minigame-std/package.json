{
  "name": "minigame-std",
  "description": "Cross-platform standard library for WeChat minigame and web browsers with unified APIs for crypto, fs, fetch, storage, and more.",
  "author": "jiang115jie@gmail.com",
  "license": "MIT",
  "version": "2.7.0",
  "type": "module",
  "main": "dist/main.cjs",
  "module": "dist/main.mjs",
  "types": "dist/types/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.cjs",
      "default": "./dist/main.mjs"
    },
    "./audio": {
      "types": "./dist/types/audio.d.ts",
      "import": "./dist/audio.mjs",
      "require": "./dist/audio.cjs",
      "default": "./dist/audio.mjs"
    },
    "./clipboard": {
      "types": "./dist/types/clipboard.d.ts",
      "import": "./dist/clipboard.mjs",
      "require": "./dist/clipboard.cjs",
      "default": "./dist/clipboard.mjs"
    },
    "./codec": {
      "types": "./dist/types/codec.d.ts",
      "import": "./dist/codec.mjs",
      "require": "./dist/codec.cjs",
      "default": "./dist/codec.mjs"
    },
    "./cryptos": {
      "types": "./dist/types/cryptos.d.ts",
      "import": "./dist/cryptos.mjs",
      "require": "./dist/cryptos.cjs",
      "default": "./dist/cryptos.mjs"
    },
    "./event": {
      "types": "./dist/types/event.d.ts",
      "import": "./dist/event.mjs",
      "require": "./dist/event.cjs",
      "default": "./dist/event.mjs"
    },
    "./fetch": {
      "types": "./dist/types/fetch.d.ts",
      "import": "./dist/fetch.mjs",
      "require": "./dist/fetch.cjs",
      "default": "./dist/fetch.mjs"
    },
    "./fs": {
      "types": "./dist/types/fs.d.ts",
      "import": "./dist/fs.mjs",
      "require": "./dist/fs.cjs",
      "default": "./dist/fs.mjs"
    },
    "./image": {
      "types": "./dist/types/image.d.ts",
      "import": "./dist/image.mjs",
      "require": "./dist/image.cjs",
      "default": "./dist/image.mjs"
    },
    "./lbs": {
      "types": "./dist/types/lbs.d.ts",
      "import": "./dist/lbs.mjs",
      "require": "./dist/lbs.cjs",
      "default": "./dist/lbs.mjs"
    },
    "./logger": {
      "types": "./dist/types/logger.d.ts",
      "import": "./dist/logger.mjs",
      "require": "./dist/logger.cjs",
      "default": "./dist/logger.mjs"
    },
    "./network": {
      "types": "./dist/types/network.d.ts",
      "import": "./dist/network.mjs",
      "require": "./dist/network.cjs",
      "default": "./dist/network.mjs"
    },
    "./path": {
      "types": "./dist/types/path.d.ts",
      "import": "./dist/path.mjs",
      "require": "./dist/path.cjs",
      "default": "./dist/path.mjs"
    },
    "./performance": {
      "types": "./dist/types/performance.d.ts",
      "import": "./dist/performance.mjs",
      "require": "./dist/performance.cjs",
      "default": "./dist/performance.mjs"
    },
    "./platform": {
      "types": "./dist/types/platform.d.ts",
      "import": "./dist/platform.mjs",
      "require": "./dist/platform.cjs",
      "default": "./dist/platform.mjs"
    },
    "./socket": {
      "types": "./dist/types/socket.d.ts",
      "import": "./dist/socket.mjs",
      "require": "./dist/socket.cjs",
      "default": "./dist/socket.mjs"
    },
    "./storage": {
      "types": "./dist/types/storage.d.ts",
      "import": "./dist/storage.mjs",
      "require": "./dist/storage.cjs",
      "default": "./dist/storage.mjs"
    },
    "./utils": {
      "types": "./dist/types/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.cjs",
      "default": "./dist/utils.mjs"
    },
    "./video": {
      "types": "./dist/types/video.d.ts",
      "import": "./dist/video.mjs",
      "require": "./dist/video.cjs",
      "default": "./dist/video.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "check": "pnpm exec tsc --noEmit",
    "lint": "pnpm exec eslint .",
    "prebuild": "pnpm run check && pnpm run lint",
    "build": "node build.ts && pnpm exec rollup --config rollup.config.ts",
    "verify:package": "pnpm run build && node verify_package.ts",
    "docs": "pnpm exec typedoc",
    "prepublishOnly": "pnpm run verify:package",
    "test": "pnpm exec vitest run --coverage",
    "test:node": "pnpm exec vitest run --project node",
    "test:watch": "pnpm exec vitest watch",
    "test:ui": "pnpm exec vitest --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JiangJie/minigame-std.git"
  },
  "keywords": [
    "minigame",
    "mini-game",
    "wechat",
    "weixin",
    "wx",
    "qq",
    "douyin",
    "tt",
    "alipay",
    "my",
    "mina",
    "cross-platform",
    "browser",
    "std",
    "standard-library",
    "fetch",
    "request",
    "fs",
    "filesystem",
    "opfs",
    "storage",
    "crypto",
    "md5",
    "sha",
    "hmac",
    "rsa",
    "random",
    "uuid",
    "base64",
    "codec",
    "socket",
    "websocket",
    "clipboard",
    "network",
    "audio",
    "webaudio",
    "video",
    "image",
    "performance",
    "event",
    "lbs",
    "geolocation",
    "location",
    "platform",
    "device"
  ],
  "dependencies": {
    "@happy-ts/fetch-t": "^1.10.0",
    "fflate": "^0.8.3",
    "happy-codec": "^1.2.2",
    "happy-opfs": "^2.1.0",
    "happy-rusty": "^1.10.0",
    "minigame-api-typings": "^3.8.20",
    "rsa-oaep-encryption": "^1.2.1",
    "tiny-future": "^1.2.0"
  }
}
