{
  "name": "minigame-std-monorepo",
  "private": true,
  "description": "Monorepo for minigame-std library and test projects",
  "scripts": {
    "check": "pnpm -r run check",
    "lint": "pnpm -r run lint",
    "build": "pnpm -r run build",
    "test": "pnpm --filter minigame-std test",
    "test:watch": "pnpm --filter minigame-std test:watch",
    "test:ui": "pnpm --filter minigame-std test:ui",
    "docs": "pnpm --filter minigame-std docs",
    "build:std": "pnpm --filter minigame-std build",
    "build:test": "pnpm --filter minigame-test build",
    "playwright:install": "pnpm exec playwright install chromium-headless-shell"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.2",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.3.0",
    "playwright": "^1.59.1",
    "rollup": "^4.60.3",
    "rollup-plugin-dts": "^6.4.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
